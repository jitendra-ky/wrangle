# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_ENV=production
DEBUG=0
SECRET_KEY=replace-this-with-a-real-secret-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL (points to the 'db' service inside the Compose network) ────────
DB_NAME=wrangle
DB_USER=wrangle
DB_PASSWORD=wrangle
DB_HOST=db
DB_PORT=5432

# ── Redis (points to the 'redis' service, plain TCP — no TLS) ────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USE_TLS=0
# REDIS_PASSWORD is intentionally blank for local Redis container

# ── LLM ──────────────────────────────────────────────────────────────────────
# Replace with your real Gemini API key before running docker compose up
GEMINI_API_KEY=your-gemini-api-key-here
